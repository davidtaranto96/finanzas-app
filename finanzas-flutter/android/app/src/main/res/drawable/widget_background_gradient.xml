<?xml version="1.0" encoding="utf-8"?>
<!-- Fondo oscuro con sutil gradient violeta→verde (estilo app) -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#F01A1A28" />
            <corners android:radius="20dp" />
            <stroke android:width="1dp" android:color="#306C63FF" />
        </shape>
    </item>
    <item android:top="0dp" android:left="0dp" android:right="0dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#206C63FF"
                android:endColor="#155ECFB1"
                android:angle="135" />
            <corners android:radius="20dp" />
        </shape>
    </item>
</layer-list>
