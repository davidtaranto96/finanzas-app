<?xml version="1.0" encoding="utf-8"?>
<!-- Widget Cotizaciones: Dólar Blue destacado + Oficial/Tarjeta abajo -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_background_gradient">

    <!-- Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cotizaciones"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.02" />

    <!-- Dólar Blue destacado -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/widget_card_primary">

        <TextView
            android:id="@+id/dollar_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dólar Blue"
            android:textColor="#6C63FF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom"
            android:layout_marginTop="2dp">

            <TextView
                android:id="@+id/dollar_venta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$0"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1" />

            <TextView
                android:id="@+id/dollar_compra"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="compra $0"
                android:textColor="#AAAAAA"
                android:textSize="10sp"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="3dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Lower row: Oficial + Tarjeta -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="6dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp"
            android:background="@drawable/widget_card_secondary">

            <TextView
                android:id="@+id/dollar_oficial_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Oficial"
                android:textColor="#5ECFB1"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/dollar_oficial_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$0"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:layout_marginTop="1dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/widget_card_secondary">

            <TextView
                android:id="@+id/dollar_tarjeta_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tarjeta"
                android:textColor="#FFB547"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/dollar_tarjeta_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$0"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:layout_marginTop="1dp" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
